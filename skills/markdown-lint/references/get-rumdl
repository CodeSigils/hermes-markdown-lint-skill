#!/bin/bash
# Downloads rumdl binary to ~/.local/bin/rumdl on first run.
# Idempotent — safe to re-run. Checks sha256 to avoid re-downloading.

set -euo pipefail

RUMDL_VERSION="v0.1.76"
INSTALL_DIR="${XDG_DATA_HOME:-$HOME/.local/bin}"
DEST="$INSTALL_DIR/rumdl"
CACHE="$HOME/.cache/rumdl/sha256"

# Detect OS and arch
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH="$(uname -m)"

case "$ARCH" in
    x86_64) ARCH="x86_64" ;;
    aarch64|arm64) ARCH="aarch64" ;;
    *)
        echo "get-rumdl: unsupported architecture: $ARCH" >&2
        exit 1
        ;;
esac

case "$OS" in
    linux) PLATFORM="unknown-linux-musl" ;;
    darwin) PLATFORM="apple-darwin" ;;
    *)
        echo "get-rumdl: unsupported OS: $OS" >&2
        exit 1
        ;;
esac

TARBALL="rumdl-${RUMDL_VERSION}-${ARCH}-${PLATFORM}.tar.gz"
URL="https://github.com/rvben/rumdl/releases/download/${RUMDL_VERSION}/${TARBALL}"
EXPECTED_SHA="2704d3ce31b4a3f6d96ef313473ec1d5538f05caeb8d6c64016df31bb7ee537c"

mkdir -p "$INSTALL_DIR"
mkdir -p "$(dirname "$CACHE")"

# Verify existing binary
if [ -f "$DEST" ] && [ -x "$DEST" ]; then
    ACTUAL_SHA=$(sha256sum "$DEST" 2>/dev/null | cut -d' ' -f1)
    if [ "$ACTUAL_SHA" = "$EXPECTED_SHA" ]; then
        exit 0
    fi
fi

# Download and verify
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

echo "get-rumdl: downloading rumdl ${RUMDL_VERSION} for ${ARCH}-${PLATFORM}..."
curl -fsSL "$URL" -o "$TMPDIR/${TARBALL}"
ACTUAL_SHA=$(sha256sum "$TMPDIR/${TARBALL}" | cut -d' ' -f1)

if [ "$ACTUAL_SHA" != "$EXPECTED_SHA" ]; then
    echo "get-rumdl: SHA256 mismatch! Got $ACTUAL_SHA, expected $EXPECTED_SHA" >&2
    exit 1
fi

tar xzf "$TMPDIR/${TARBALL}" -C "$TMPDIR"
mv "$TMPDIR/rumdl" "$DEST"
chmod +x "$DEST"
echo "get-rumdl: installed to $DEST"

# Ensure it's on PATH for this session
if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
    export PATH="$INSTALL_DIR:$PATH"
fi
